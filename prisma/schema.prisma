generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ==========================================
// 🧑‍💼 CORE MEMBERSHIP & DASHBOARD ECOSYSTEM
// ==========================================

model User {
  id           Int           @id @default(autoincrement())
  name         String        @default("User")
  email        String        @unique
  password     String
  applications Application[]
  logs         Activity[]
}

model Job {
  id           Int           @id @default(autoincrement())
  title        String
  description  String        @default("")
  applications Application[]
}

model Application {
  id     Int  @id @default(autoincrement())
  userId Int
  jobId  Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Activity {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 📂 Network Registry with Google Maps Coordinate support:
model NetworkRegistry {
  id           Int      @id @default(autoincrement())
  userId       Int?
  fullName     String
  email        String
  phone        String
  country      String
  city         String
  postalCode   String
  fullAddress  String
  latitude     Float?
  longitude    Float?
  sector       String
  businessName String?
  createdAt    DateTime @default(now())
}

// ==========================================
// 🏦 REMITTANCE & SACCO INTEGRATED LEDGER
// ==========================================

model RemittanceLog {
  id                  String             @id @default(uuid())
  senderId            String
  recipientName       String
  recipientAccount    String
  amount              Float
  currency            String             @default("UGX")
  gateway             String             @default("mpesa")
  status              String             @default("PENDING")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  // 🔗 Connection Nodes back to SACCO Capital Accounts
  isSaccoDeposit      Boolean            @default(false)
  saccoSubscriptionId String?
  saccoSubscription   SaccoSubscription? @relation(fields: [saccoSubscriptionId], references: [id])

  @@index([senderId])
}

model SaccoSubscription {
  id               String          @id @default(uuid())
  memberSacco      String
  membershipType   String
  idType           String
  idNumber         String
  sharesCapital    Float           // Initial Equity Injection
  balanceUGX       Float           @default(0.0) // Running Ledger Cash Pool
  complianceAgreed Boolean         @default(true)
  status           String          @default("ACTIVE")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // 🔗 Connection Tracking mapping incoming investment cashflows
  remittances      RemittanceLog[]

  @@index([idNumber])
}

// ==========================================
// 📞 VOIP COMMUNICATIONS ARRAY
// ==========================================

model VoipAccount {
  id            String        @id @default(uuid())
  userId        Int           @unique
  virtualNumber String        @unique
  balanceUGX    Float         @default(5000.0)
  tierClass     String        @default("DIASPORA_STANDARD")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  callLogs      VoipCallLog[]
}

model VoipCallLog {
  id            String      @id @default(uuid())
  voipAccountId String
  account       VoipAccount @relation(fields: [voipAccountId], references: [id], onDelete: Cascade)
  destinationNo String
  durationSecs  Int
  costUGX       Float
  status        String      @default("COMPLETED")
  createdAt     DateTime    @default(now())
}
